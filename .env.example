# PostgreSQL
POSTGRES_USER=bioplatform
POSTGRES_PASSWORD=bioplatform
POSTGRES_DB=bioplatform

# Backend async URL (used by FastAPI)
DATABASE_URL=postgresql+asyncpg://bioplatform:bioplatform@postgres:5432/bioplatform

# Backend sync URL (used by Celery worker)
# DATABASE_URL_SYNC=postgresql+psycopg2://bioplatform:bioplatform@postgres:5432/bioplatform

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Storage backend: local | s3
STORAGE_BACKEND=local

# EC2 backend: mock | aws
EC2_BACKEND=mock

# HLA backend: mock | hlahd
HLA_BACKEND=mock

# Local uploads directory (shared volume)
UPLOADS_DIR=/uploads

# --- Production overrides (uncomment and fill for real deployment) ---
# STORAGE_BACKEND=s3
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# S3_BUCKET=my-hla-uploads

# EC2_BACKEND=aws
# EC2_KEY_PAIR=my-key-pair
# EC2_SUBNET_ID=subnet-...
# EC2_SECURITY_GROUP_ID=sg-...

# HLA_BACKEND=hlahd
# HLAHD_PATH=/opt/hlahd/bin/hlahd.sh
# HLAHD_DB_PATH=/opt/hlahd/database
