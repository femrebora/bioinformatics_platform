# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local          # local | s3

# ── Nextflow (sarek) ─────────────────────────────────────────────────────────
NEXTFLOW_BACKEND=local         # mock | local | awsbatch
NEXTFLOW_PROFILE=docker        # docker | singularity  (local mode only)

# ── Other runners (keep mock until implemented) ───────────────────────────────
SNAKEMAKE_BACKEND=mock
BIOSCRIPT_BACKEND=mock
CUSTOM_BACKEND=mock

# ── Auth / Security ───────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
DATABASE_URL=postgresql://bioplatform:bioplatform@postgres:5432/bioplatform

# ── AWS (required when NEXTFLOW_BACKEND=awsbatch or STORAGE_BACKEND=s3) ───────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=

# ── Stripe (optional, for payments) ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
