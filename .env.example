# ── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local          # local | s3

# ── Nextflow (sarek) ─────────────────────────────────────────────────────────
NEXTFLOW_BACKEND=mock          # mock | local | aws
NEXTFLOW_PROFILE=docker        # docker | singularity  (local mode only)

# ── Other runners ──────────────────────────────────────────────────────────────
SNAKEMAKE_BACKEND=mock         # mock | aws
BIOSCRIPT_BACKEND=mock         # mock | aws
CUSTOM_BACKEND=mock            # mock | aws

# ── Mutation Assessment ────────────────────────────────────────────────────────
# Genome build for gnomAD / VEP / CADD lookups (hg19 | hg38)
ASSESSMENT_GENOME=hg38

# OMIM — gene-disease relationships (free academic key: omim.org/api)
OMIM_API_KEY=

# Orphanet — rare disease associations (free key: orphacode.org)
ORPHANET_API_KEY=

# ── Auth / Security ───────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production
DATABASE_URL=postgresql://bioplatform:bioplatform@postgres:5432/bioplatform

# ── AWS (required when NEXTFLOW_BACKEND=awsbatch or STORAGE_BACKEND=s3) ───────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET=

# ── Stripe (optional, for payments) ──────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
