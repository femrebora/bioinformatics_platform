/*
 * Nextflow configuration for AWS Batch execution.
 * All tunables are injected via environment variables by the Celery worker.
 * This file is passed with: nextflow run ... -c /app/nextflow_aws.config
 */

plugins {
    id 'nf-amazon'
}

// Tell Nextflow to resolve process containers as Docker images.
// With executor=awsbatch this does NOT run Docker locally —
// it formats the container spec for Batch job definitions.
docker.enabled = true

process {
    executor      = 'awsbatch'
    queue         = System.getenv('NF_BATCH_QUEUE') ?: 'bioplatform-default'
    // Retry on common transient exit codes (OOM-kill, signal, spot interruption)
    errorStrategy = { task.exitStatus in [143, 137, 104, 134, 139] ? 'retry' : 'finish' }
    maxRetries    = 2
}

aws {
    region = System.getenv('AWS_REGION') ?: 'us-east-1'
    batch {
        jobRole = System.getenv('NF_BATCH_JOB_ROLE') ?: ''
        volumes = '/tmp'
        // No cliPath set → Nextflow uses its native nf-amazon S3 client.
        // This means no aws cli is required inside Batch job containers.
    }
    client {
        maxConnections       = 20
        connectionTimeout    = 10000
        maxErrorRetry        = 5
    }
}
